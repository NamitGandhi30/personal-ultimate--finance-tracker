# SQLite fallback for local development:
DATABASE_URL=sqlite:///./puft.db

# App login for the FastAPI endpoints.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=replace-with-a-long-random-string

